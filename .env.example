PORT=8080
DATABASE_URL=postgresql://postgres:password@hostname.railway.app:5432/railway
# Run AutoMigrate (default: false). Set to true only when schema changes are needed.
AUTO_MIGRATE=false

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-project.firebaseapp.com
FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Either set the JSON itself...
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-firebase-project-id"}
